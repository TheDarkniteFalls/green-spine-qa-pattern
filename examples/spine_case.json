    "30 days"
  ],
  "model_output": "{\"answer\":\"The supplied ticket has refund evidence: the policy allows refunds within 30 days.\",\"action\":\"summarize\",\"citations\":[\"ticket:001\",\"policy:refunds\"],\"writes\":[]}",
